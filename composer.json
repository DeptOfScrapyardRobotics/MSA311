{
    "name": "dept-of-scrapyard-robotics/msa3xx",
    "description": "Drive MSA301 and MSA311 motion sensors over I2C with PHP",
    "type": "library",
    "version": "0.4.0",
    "keywords": [
        "framework",
        "scrapyard-io"
    ],
    "license": "MIT",
    "homepage": "https://dosr.projectsaturnstudios.com",
    "authors": [
        {
            "name": "Angel Gonzalez",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "scrapyard-io/waveforms": "^0.4.0",
        "scrapyard-io/reality-interface": "^0.4.0",
        "scrapyard-io/bare-metal": "^0.4.0"
    },
    "suggest": {
        "scrapyard-io/gpio": "^0.4.0 - For direct linux-based GPIO",
        "scrapyard-io/i2c": "^0.4.0 - For direct linux-based I2C",
        "scrapyard-io/mpsse": "^0.4.0 - For I2C/GPIO over an FTDI Serial-to-USB Device"
    },
    "autoload": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Sensors\\MSA3xx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
