{
    "name": "dept-of-scrapyard-robotics/msa311",
    "description": "Drive MSA311 accelerometers over I2C with PHP",
    "type": "library",
    "version": "0.5.0",
    "keywords": [
        "framework",
        "scrapyard-io"
    ],
    "license": "MIT",
    "homepage": "https://dosr.projectsaturnstudios.com",
    "authors": [
        {
            "name": "Angel Gonzalez",
            "email": "angel@projectsaturnstudios.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "waveforms/i2c": "^0.5.0",
        "bare-metal/circuits": "^0.5.0",
        "bare-metal/sensors": "^0.5.0",
        "scrapyard-io/nuts-and-bolts": "^0.5.0"
    },
    "suggest": {
        "ext-posi": "^0.4.0",
        "ext-ftdi": "^0.4.0",
        "microscrap/posix": "^0.5.0",
        "microscrap/mpsse": "^0.5.0",
        "waveforms/digital": "^0.5.0",
        "waveforms/i2c": "^0.5.0"
    },
    "autoload": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Sensors\\MSA311\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DeptOfScrapyardRobotics\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
